{
  "name": "elected-election-education",
  "version": "2.2.0",
  "description": "ElectEd — AI-powered interactive U.S. election process education platform",
  "main": "js/app.js",
  "homepage": "https://pranavmathwad02-prog.github.io/promptwars/",
  "repository": {
    "type": "git",
    "url": "https://github.com/pranavmathwad02-prog/promptwars"
  },
  "scripts": {
    "test":     "jest --coverage --verbose --forceExit",
    "test:watch": "jest --watch --forceExit",
    "test:ci":  "jest --coverage --ci --forceExit --detectOpenHandles --reporters=default",
    "serve":    "python serve.py",
    "lint":     "echo 'No linter configured — add eslint for production'"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "js/api/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches":   80,
        "functions":  90,
        "lines":      90,
        "statements": 90
      }
    }
  },
  "keywords": [
    "election",
    "civics",
    "education",
    "democracy",
    "voting",
    "google-gemini",
    "firebase",
    "leaflet",
    "pwa",
    "hackathon"
  ],
  "author": "ElectEd — Pranav Mathwad",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "python": ">=3.10"
  },
  "devDependencies": {
    "jest": "29.7.0"
  }
}
